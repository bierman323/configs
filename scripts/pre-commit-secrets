#!/usr/bin/env bash
#
# pre-commit-secrets -- Block commits containing secrets
#
# Scans staged files for common secret patterns:
#   AWS keys, private keys, API tokens, passwords, high-entropy strings
#
# Install: copy or symlink to .git/hooks/pre-commit
# Bypass:  git commit --no-verify  (use with caution)
# Ignore:  add patterns to .secretsignore (one regex per line)
#
# No third-party dependencies. Pure bash + grep.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

FINDINGS=0
FINDING_DETAILS=""

# ── Pattern definitions ──────────────────────────────────────────────
# Each pattern: "LABEL:::REGEX"
# Using extended grep (-E). Patterns run against staged diff content.

PATTERNS=(
  # AWS
  "AWS Access Key ID:::(A3T[A-Z0-9]|AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}"
  "AWS Secret Access Key:::(?i)(aws_secret_access_key|aws_secret_key|secret_key)\s*[=:]\s*[A-Za-z0-9/+=]{40}"

  # Private keys
  "Private Key:::BEGIN.*PRIVATE KEY"

  # GitHub tokens
  "GitHub Token:::(ghp|gho|ghu|ghs|ghr|github_pat)_[A-Za-z0-9_]{36,255}"

  # Generic tokens/secrets in assignments
  "Generic API Key:::(?i)(api_key|apikey|api_secret|api_token)\s*[=:]\s*['\"][A-Za-z0-9_\-]{20,}['\"]"
  "Generic Secret:::(?i)(secret_key|secret_token|client_secret|app_secret)\s*[=:]\s*['\"][A-Za-z0-9_\-]{20,}['\"]"
  "Generic Token:::(?i)(access_token|auth_token|bearer_token)\s*[=:]\s*['\"][A-Za-z0-9_\-]{20,}['\"]"
  "Generic Password:::(?i)(password|passwd|pwd)\s*[=:]\s*['\"][^'\"]{8,}['\"]"

  # Bearer tokens in code
  "Bearer Token:::(?i)bearer\s+[A-Za-z0-9_\-\.]{20,}"

  # Slack tokens
  "Slack Token:::xox[bpors]-[A-Za-z0-9\-]{10,}"

  # Google API
  "Google API Key:::AIza[0-9A-Za-z_\-]{35}"

  # Stripe
  "Stripe Key:::(sk|pk)_(test|live)_[A-Za-z0-9]{20,}"

  # OpenAI
  "OpenAI API Key:::sk-[A-Za-z0-9]{20,}"

  # Anthropic
  "Anthropic API Key:::sk-ant-[A-Za-z0-9_\-]{20,}"

  # Generic high-value exports
  "Exported Secret:::(?i)export\s+(AWS_SECRET|API_KEY|SECRET_KEY|ACCESS_TOKEN|AUTH_TOKEN|PRIVATE_KEY|PASSWORD|ANTHROPIC_API_KEY|OPENAI_API_KEY|GITHUB_TOKEN)[=]['\"]?[^\s'\"]+['\"]?"
)

# ── Load ignore patterns ─────────────────────────────────────────────
IGNORE_FILE="$(git rev-parse --show-toplevel 2>/dev/null)/.secretsignore"
IGNORE_PATTERNS=()
if [[ -f "$IGNORE_FILE" ]]; then
  while IFS= read -r line; do
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    IGNORE_PATTERNS+=("$line")
  done < "$IGNORE_FILE"
fi

should_ignore() {
  local match="$1"
  for pattern in "${IGNORE_PATTERNS[@]}"; do
    if echo "$match" | grep -qP "$pattern" 2>/dev/null || echo "$match" | grep -qE "$pattern" 2>/dev/null; then
      return 0
    fi
  done
  return 1
}

# ── Get staged files ─────────────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# Skip binary files and common non-secret files
skip_file() {
  local f="$1"
  case "$f" in
    *.png|*.jpg|*.jpeg|*.gif|*.ico|*.svg|*.woff|*.woff2|*.ttf|*.eot|*.pdf|*.zip|*.tar|*.gz|*.lock|*.sum)
      return 0 ;;
    # Skip the hook itself (contains pattern strings that trigger false positives)
    */pre-commit-secrets|scripts/pre-commit-secrets)
      return 0 ;;
    *)
      return 1 ;;
  esac
}

# ── Scan staged content ──────────────────────────────────────────────
for file in $STAGED_FILES; do
  skip_file "$file" && continue

  # Get the staged version of the file
  staged_content=$(git show ":$file" 2>/dev/null || true)
  [[ -z "$staged_content" ]] && continue

  for entry in "${PATTERNS[@]}"; do
    label="${entry%%:::*}"
    pattern="${entry##*:::}"

    # Try perl-compatible grep first, fall back to extended
    matches=$(echo "$staged_content" | grep -nP "$pattern" 2>/dev/null || echo "$staged_content" | grep -nE "$pattern" 2>/dev/null || true)

    if [[ -n "$matches" ]]; then
      while IFS= read -r match_line; do
        [[ -z "$match_line" ]] && continue

        # Check against ignore patterns
        if [[ ${#IGNORE_PATTERNS[@]} -gt 0 ]] && should_ignore "$match_line"; then
          continue
        fi

        line_num="${match_line%%:*}"
        FINDINGS=$((FINDINGS + 1))
        FINDING_DETAILS+="  ${RED}[$label]${RESET} ${file}:${line_num}\n"
        # Show truncated match (don't print the actual secret)
        snippet="${match_line#*:}"
        if [[ ${#snippet} -gt 80 ]]; then
          snippet="${snippet:0:77}..."
        fi
        FINDING_DETAILS+="    ${YELLOW}${snippet}${RESET}\n"
      done <<< "$matches"
    fi
  done
done

# ── Report ───────────────────────────────────────────────────────────
if [[ $FINDINGS -gt 0 ]]; then
  echo ""
  echo -e "${RED}${BOLD}SECRET SCAN FAILED${RESET} -- $FINDINGS potential secret(s) found in staged files:"
  echo ""
  echo -e "$FINDING_DETAILS"
  echo -e "${YELLOW}${BOLD}Commit blocked.${RESET} Options:"
  echo "  1. Remove the secret from the file"
  echo "  2. Move it to a *_sensitive file (git-ignored)"
  echo "  3. Add a regex to .secretsignore for false positives"
  echo "  4. git commit --no-verify  (bypass -- use with extreme caution)"
  echo ""
  exit 1
else
  echo -e "${GREEN}Secret scan passed${RESET} -- no secrets detected in staged files."
  exit 0
fi
