# GTD System Configuration
# Generated by gtd-setup.sh — edit as needed

# Core paths
GTD_BIN_DIR="$HOME/organize/gtd-scripts"

# Context detection: work vs home based on which obsidian symlink resolves
# The symlinks are the single source of truth — move the target folders freely
if [ -d "$HOME/obsidian/Work-Tasks" ]; then
    GTD_CONTEXT="work"
    GTD_TASKS_DIR="$(cd "$HOME/obsidian/Work-Tasks" && pwd -P)"
    GTD_DATAVIEW_FOLDER="Work-Tasks"
elif [ -d "$HOME/obsidian/tasks" ]; then
    GTD_CONTEXT="home"
    GTD_TASKS_DIR="$(cd "$HOME/obsidian/tasks" && pwd -P)"
    GTD_DATAVIEW_FOLDER="tasks"
else
    GTD_CONTEXT="unknown"
    GTD_TASKS_DIR="$HOME/organize/tasks"
    GTD_DATAVIEW_FOLDER="Tasks"
fi

# Obsidian paths
GTD_VAULT_DIR="$HOME/obsidian"
GTD_INBOX_DIR="$HOME/obsidian/Inbox"
GTD_DAILY_NOTES_DIR="$HOME/obsidian/Daily Notes"
GTD_INBOX_PATH="Inbox"

# Obsidian REST API (from Local REST API plugin)
GTD_OBSIDIAN_API="https://127.0.0.1:27124"
GTD_OBSIDIAN_API_KEY="${GTD_OBSIDIAN_API_KEY}"

# Apple Reminders list name
GTD_REMINDERS_LIST="Brain Dump"
